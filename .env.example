# .env にコピーして埋める。本番(香橙派 / 将来の x86_64 機)は別の env ファイルを使う。

# 管制面 Postgres(infra/docker-compose.yml → just db-up)
DATABASE_URL=postgres://tsubomi:tsubomi_dev@localhost:5434/tsubomi_platform

# Google OAuth(https://console.cloud.google.com/apis/credentials で作成)
# Authorized redirect URI に下の値を登録すること。
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/api/auth/google/callback

# 正規の外部 URL(末尾スラッシュなし。dev では vite のオリジン)
TSUBOMI_SERVER_URL=http://localhost:5173

# WebSocket(ターミナル / metrics)升级で許可する管制面オリジンの追加(CSWSH 対策)。
# 既定で TSUBOMI_SERVER_URL は常に許可される。管制面が複数オリジンを持つ場合だけ
# カンマ区切りで追加する(通常は未設定でよい)。例:TSUBOMI_CONTROL_ORIGIN=https://paas.example.com
# TSUBOMI_CONTROL_ORIGIN=

# 登録ドメイン制限:会社の Google Workspace ドメイン(カンマ区切りで複数可)。
# hd claim と email ドメインの両方がリストに入っていないと拒否。
TSUBOMI_ALLOWED_HD=example.co.jp,example2.co.jp

# owner の種(最大 2 名、カンマ区切り。ログイン時に昇格を適用)
TSUBOMI_OWNER_EMAILS=owner@example.co.jp

# cookie 属性 — HTTP の localhost dev では false、HTTPS 本番では true
TSUBOMI_COOKIE_SECURE=false

# CLI リリース manifest の置き場(/api/cli/version を配信)。未設定 = リリース未発行。
# TSUBOMI_RELEASE_DIR=/srv/tsubomi/releases

# ===== M1 database =====
# pg-tenant(ユーザ DB)admin パスワード。**本番(compose.prod.yml)では必須**。
# compose の PG_TENANT_PASSWORD と TENANT_ADMIN_URL 内のパスワードを一致させる。
# secret は **英数字のみ**(compose の inline 設定に插值されるので `"` 改行 `$` は避ける)。
PG_TENANT_PASSWORD=tsubomi_tenant_dev
# pg-tenant の admin 接続(infra の pg-tenant、loopback :5435)。
TENANT_ADMIN_URL=postgres://tsubomi_admin:tsubomi_tenant_dev@localhost:5435/postgres
# ----- DB 接続プール -----
# LAN 実測の結論:このプール幅はスループットの律速ではない(/api/databases は 10→50 に広げても
# ~2350 rps 頭打ち = CPU/IPC 律速)。未設定なら下の既定が効く(本番でも安全)。
# **子網 CIDR の TSUBOMI_TENANT_POOL とは無関係**(別物)。
# 管制面プール(DATABASE_URL = pg-platform)。全認証リクエストが取り合う。
# TSUBOMI_DB_MAX_CONN=20    # 最大接続。実測でスループット律速ではない(CPU/IPC が律速)— 遅い query が
#                           # 接続を握っても速い認証を待たせない余裕。Postgres の max_connections 未満で。
# TSUBOMI_DB_MIN_CONN=5     # 常時保温する最小接続(冷えた接続確立コストを消す)。
# pg-tenant への admin(DDL / web SQL)プール。
# TSUBOMI_TENANT_ADMIN_MAX_CONN=10
# pgbouncer の auth_user パスワード。**本番では必須**(compose は未設定だと起動を拒否)。
# 英数字のみ。dev(infra/docker-compose.yml)は未設定なら tsubomi_pgb_dev に既定。
PGBOUNCER_AUTH_PASSWORD=tsubomi_pgb_dev
# human が手にする外部接続文字列のホスト / ポート(pgbouncer)。
# dev はローカルの pgbouncer に直結するので localhost:6432。
# 本番(公網 VPS 中継)は **443**:会社出口の防火墙が DB ポート(5432/6432)を塞ぐため、
# VPS 辺縁の SNI 闸门(tsubomi-sni-gate)を公網 443 に置き、libpq は :443 で素通し接続する
# (闸门は TLS を終端せず SNI=db.tsubomi-app.com だけ通す)。本番は .env.production で
# TSUBOMI_DB_PUBLIC_PORT=443。**VPS の provider 防火墙でも 443 inbound を開けること**
# (詳細は incident-frp-pg-public-*.md / crates/sni-gate/ / deploy/sni-gate/)。
TSUBOMI_DB_PUBLIC_HOST=localhost
TSUBOMI_DB_PUBLIC_PORT=6432
# **内部**(service 注入の app role)接続文字列の sslmode(dev=disable、本番=require)。
# 内部は tsubomi-pgbouncer へ docker DNS で繋ぐので証明書 SAN と一致せず require 据え置き。
TSUBOMI_DB_SSLMODE=disable
# **外部**(human の公開接続文字列)の sslmode。未設定なら上の内部に追従。公網 VPS 中継 +
# 公開 LE 証明書の部署では verify-full にする(build_url が sslrootcert=system を自動付与)。
# TSUBOMI_DB_SSLMODE_EXTERNAL=verify-full
# 外部接続文字列を提供するか(既定 false)。CF Tunnel など公網 TCP 入口を持たない部署では
# false にして web の接続文字列カードを隠し /url・/rotate も後端で拒否する(届かない LAN IP の
# 誤誘導を断つ)。公網 IP の VPS では true。dev はローカルから psql で試せるよう true。
TSUBOMI_DB_PUBLIC_ENABLED=true
# service へ注入する内部入口(コンテナ → edge 上の pgbouncer を docker DNS で引く)。外部入口
# (DB_PUBLIC_HOST)とは別。dev/本番とも compose のサービス名 = tsubomi-pgbouncer:6432。
TSUBOMI_DB_INTERNAL_HOST=tsubomi-pgbouncer
TSUBOMI_DB_INTERNAL_PORT=6432
# at-rest 暗号化の master key:base64 of 32 bytes。例: `head -c 32 /dev/urandom | base64`
TSUBOMI_MASTER_KEY=
# バックアップ / ゴミ箱 dump の置き場(server ホスト上、要書き込み権)。
TSUBOMI_BACKUP_DIR=/srv/tsubomi/backups
TSUBOMI_TRASH_DIR=/srv/tsubomi/trash

# ===== M2 volume =====
# volume 実体の置き場(server ホスト上、要書き込み権)。同一 FS 上に trash があると
# 削除(ゴミ箱への mv)がほぼゼロコストになる。
TSUBOMI_VOLUMES_DIR=/srv/tsubomi/volumes
# ファイルアップロードの 1 リクエスト上限(バイト)。既定 100 MiB。
# TSUBOMI_MAX_UPLOAD_BYTES=104857600

# ===== M3 service =====
# service の subdomain のルートドメイン。ルーティングは <subdomain>.<domain>。
# dev=localhost(ブラウザが *.localhost を 127.0.0.1 に解決)。本番は会社ドメイン。
TSUBOMI_DOMAIN=localhost
# 平台が digest 指定で pull する registry の host:port(localhost は insecure 許容)。
TSUBOMI_REGISTRY_PULL=127.0.0.1:5000
# GitHub Actions が docker login + push する registry の host。未設定なら PULL と同じ
# (dev は無認証の 127.0.0.1:5000)。本番は registry.<域名>(認証付き、traefik 終端)。
# TSUBOMI_REGISTRY_PUSH=registry.example.co.jp
# build 対象 arch(GitHub Variable TSUBOMI_PLATFORMS に載る)。今は香橙派のみ = linux/arm64。
# 将来 x86_64 host を足したら linux/arm64,linux/amd64 に変える(§6.6 データ駆動)。
TSUBOMI_PLATFORMS=linux/arm64
# ユーザコンテナを attach する docker ネットワーク名(traefik も参加)。
TSUBOMI_EDGE_NETWORK=tsubomi-edge
# --- 本番(prod-infra)。dev は未設定(= 既定 false)---
# TSUBOMI_TLS = 「**誰が** TLS を終端するか」。詳細手順は paas-m3-design.md §13。
#   false(既定)= **上流が終端**(Cloudflare Tunnel / CF proxy / nginx / caddy 等が前段)。
#                 traefik は HTTP :80 のみ(base = compose.prod.yml)。香橙派の CF Tunnel 構成はこれ。
#   true        = **traefik 自身が :443 + Let's Encrypt**(直 VPS)。compose.prod.tls.yml を重ねる。
# TSUBOMI_TLS=true
# Let's Encrypt 登録メール(tls=true=直VPS のときだけ。compose.prod.tls.yml が必須化)。
# TSUBOMI_ACME_EMAIL=owner@example.co.jp
# registry の push 入口(registry.<域名> + traefik basicAuth)は **REGISTRY_PUSH≠PULL なら自動で書く**
# (TLS の有無と独立 — tunnel でも書く)。registry コンテナ自体は無認証ループバック :5000 のまま。
# BIND_ADDR:上流終端(tunnel/proxy)なら 127.0.0.1:9090 で可(上流/cloudflared が apex→:9090 を直接転送)。
#   直VPSで apex も traefik 前段にするなら 0.0.0.0:9090 + ファイアウォールで公網の :9090 を塞ぐ。
# TSUBOMI_BIND_ADDR=127.0.0.1:9090

# ===== ガバナンス:IP 許可リスト =====
# 平台が traefik の動的設定(会社 IP 許可リストの ipAllowList middleware)を書き出す
# ディレクトリ。compose の traefik が file provider でこの同じホストパスを読む
# (docker-compose.yml の bind mount と一致させること)。空リスト = 全 IP 許可。
TSUBOMI_TRAEFIK_DYNAMIC_DIR=/srv/tsubomi/traefik-dynamic

# ===== ガバナンス:メール(Resend)+ ディスク水位警告(M4)=====
# Resend の API キー。未設定 = メールを送らず log だけ(dev / 未契約時)。本番で実送する。
# RESEND_API_KEY=re_xxxxxxxx
# メール送信元(RESEND_API_KEY が在る時は必須)。Resend で検証済みドメインを使う。
# TSUBOMI_MAIL_FROM=tsubomi <noreply@tsubomi-app.com>
# ディスク使用率の警告閾値(%)。gc が 1h 毎に df を見て、超えたら owner(TSUBOMI_OWNER_EMAILS)へ
# メール(level 上昇 or 24h 経過で 1 回。毎時スパムしない)。既定 warn=80 / critical=90。
# TSUBOMI_DISK_WARN_PCT=80
# TSUBOMI_DISK_CRITICAL_PCT=90

# ===== M5 cache(valkey)=====
# valkey の admin パスワード。compose の --user tsubomi-admin と TSUBOMI_VALKEY_ADMIN_URL の
# パスワードを一致させること。**本番では必須**。英数字のみ(compose の inline 設定に插值される)。
TSUBOMI_VALKEY_ADMIN_PASS=tsubomi_valkey_dev
# valkey の admin 接続(infra の valkey)。ホスト側 port は **6433**(6379 はローカル redis に
# 取られがちなので衝突回避。pg の 5434/5435 と同じ流儀)。default ユーザは off なので必ず
# tsubomi-admin で繋ぐ。dev は未設定でも上記既定で組み立てた値にフォールバックする。
TSUBOMI_VALKEY_ADMIN_URL=redis://tsubomi-admin:tsubomi_valkey_dev@127.0.0.1:6433
# 共有 valkey の最大メモリ(超過は allkeys-lru で任意 key を evict。cache は易失)。既定 256mb。
# TSUBOMI_VALKEY_MAXMEMORY=256mb
# service へ注入する内部入口(コンテナ → edge 上の valkey を docker DNS で引く)。外部入口は無い。
# dev/本番とも compose のサービス名 = tsubomi-valkey:6379。S2(注入)で使う。
# TSUBOMI_CACHE_INTERNAL_HOST=tsubomi-valkey
# TSUBOMI_CACHE_INTERNAL_PORT=6379

RUST_LOG=tsubomi_server=debug,tower_http=debug

# メール(Resend)。owner 通知 / 磁盘告警 / 検証コードに使う。未設定なら送らず log だけ(dev 退路)。
# **RESEND_API_KEY を設定するなら TSUBOMI_MAIL_FROM も必須**(無いと server 起動時に弾く)。
# from は Resend で検証済みの発件ドメイン(tsubomi-app.com 等)を使う。検証前は onboarding@resend.dev
# が使えるが Resend アカウント本人宛にしか届かない。
RESEND_API_KEY=real_key_should_be_set_in_actual_env_files_not_in_version_control
# 値に空白 / < > を含むので**必ず引用符で囲む**(dotenvy が引用無しだとこの行を取りこぼし、
# RESEND_API_KEY 有り + MAIL_FROM 無し扱いで server が起動時に弾く)。
TSUBOMI_MAIL_FROM="tsubomi <noreply@tsubomi-app.com>"
